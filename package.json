{
  "name": "flight-alert",
  "version": "1.0.0",
  "description": "Monitor pessoal de passagens aéreas com alertas por email",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"node backend/server.js\" \"npm run dev --prefix frontend\"",
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "NODE_ENV=production node backend/server.js",
    "install:all": "npm install && npm install --prefix frontend"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bcryptjs": "^3.0.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.12",
    "sql.js": "^1.12.0"
  }
}
